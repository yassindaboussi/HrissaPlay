{
  "name": "hrissaplay",
  "version": "1.1.0",
  "description": "HrissaPlay - Tunisian Radios Desktop Player",
  "main": "src/main/main.js",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/yassindaboussi/HrissaPlay"
  },
  "author": {
    "name": "Yassin Daboussi",
	"email":"yassin.daboussi@esprit.tn"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder -p always",
    "pack": "electron-builder --dir",
    "lint": "echo 'Linting...' || true"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "electron-log": "^4.4.8"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.hrissaplay.app",
    "productName": "HrissaPlay",
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public/icons"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icons/icon.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icons/icon.png",
      "category": "Audio"
    },
    "publish": {
      "provider": "github",
      "owner": "yassindaboussi",
      "repo": "HrissaPlay"
    }
  }
}
